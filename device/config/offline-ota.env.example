OFFLINE_OTA_ACTIVATE_COMMAND=systemctl restart offline-ota-demo.service
OFFLINE_OTA_USB_MOUNT_ROOTS=/media,/mnt
OFFLINE_OTA_HTTP_SOURCES=
OFFLINE_OTA_POLL_INTERVAL_SECONDS=60
OFFLINE_OTA_ROLLOUT_RING=general
OFFLINE_OTA_MAINTENANCE_WINDOW_START=
OFFLINE_OTA_MAINTENANCE_WINDOW_END=
OFFLINE_OTA_TRUSTED_HTTP_SOURCES=
OFFLINE_OTA_TRUSTED_USB_ROOTS=
OFFLINE_OTA_RETRY_COOLDOWN_MINUTES=30
OFFLINE_OTA_SOURCE_BACKOFF_BASE_MINUTES=5
OFFLINE_OTA_SOURCE_QUARANTINE_THRESHOLD=3
OFFLINE_OTA_SOURCE_QUARANTINE_MINUTES=60
OFFLINE_OTA_SOURCE_AFFINITY_TTL_HOURS=72
OFFLINE_OTA_SOURCE_CHANNEL_DECAY_THRESHOLD=3
OFFLINE_OTA_SOURCE_CHANNEL_DECAY_PENALTY=20
# Configure per-source policy at runtime with:
# python -m agent.main set-source-policy http://192.168.1.50:8081/ 10 01:00 05:00 15
OFFLINE_OTA_RETENTION_KEEP_RELEASES=3
OFFLINE_OTA_RELEASE_ROOT=/opt/offline-ota/artifacts/device/active
